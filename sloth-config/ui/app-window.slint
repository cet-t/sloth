import {
    Button,
    CheckBox,
    LineEdit,
    ComboBox,
    SpinBox,
    VerticalBox,
    HorizontalBox,
    ScrollView,
} from "std-widgets.slint";

export struct ProfileRow {
    name: string,
    layout: string,
    sands: bool,
    gestures: bool,
    shortcuts: bool,
}

component CategoryItem inherits Rectangle {
    in property <string> label;
    in property <bool> selected;
    callback clicked();

    height: 36px;
    background: selected ? #3a3a50 : transparent;

    Text {
        text: label;
        x: 10px;
        vertical-alignment: center;
        color: white;
        font-weight: selected ? 700 : 400;
    }

    TouchArea {
        clicked => {
            root.clicked();
        }
    }
}

export component AppWindow inherits Window {
    title: "sloth 設定";
    preferred-width: 680px;
    preferred-height: 480px;
    min-width: 680px;
    min-height: 480px;
    max-width: 680px;
    max-height: 480px;

    in-out property <int> category_index: 0;
    in-out property <string> default_layout;
    in-out property <int> default_profile_index: 0;
    in-out property <bool> enable_log;
    in-out property <bool> activate_only_when_ime_on;
    in-out property <string> ime_off_layout;
    in-out property <int> combo_window_ms;
    in-out property <bool> hold_mode;
    in-out property <int> direct_input_key_index: 0;
    in-out property <int> sands_mode_index: 0;
    in-out property <bool> enable_sands_ime_on: true;
    in-out property <bool> enable_sands_ime_off: true;
    in-out property <int> dispatch_rate_ms: 5;
    in-out property <bool> disable_ctrl;
    in-out property <bool> disable_alt;
    in-out property <bool> disable_win;
    in-out property <bool> disable_shift;
    in-out property <bool> enable_ctrl_space_ime_toggle;
    in-out property <bool> dirty: false;
    // True while the initial config is being loaded into the window. Loading
    // calls `set_X(...)` on every field, which would otherwise trip the
    // `changed` handlers below and mark the form dirty before the user has
    // touched anything; Rust flips this to false only after the load has
    // fully settled (see `run_settings_window`).
    in-out property <bool> loading: true;
    in-out property <[ProfileRow]> profiles;
    in property <[string]> profile_names;
    in-out property <int> current_profile_index: 0;
    in property <string> status_text;
    in property <string> running_status_text;
    in property <bool> daemon_suspended;
    // While true, the 再生/停止・再起動・終了 buttons are disabled. Set
    // around each async daemon-control operation so a rapid double-click
    // can't fire the same command (or the not-running auto-start fallback)
    // twice before the first one's result comes back and updates
    // daemon_suspended -- that race could otherwise spawn two daemons.
    in property <bool> daemon_op_in_flight;
    in property <string> current_profile_text;
    in property <string> current_layout_text;

    callback save();
    callback toggle_running();
    callback restart();
    callback quit();
    callback browse_default_layout();
    callback browse_ime_off_layout();
    callback open_log_file();
    callback browse_profile_layout();
    callback profile_layout_edited(string);
    callback toggle_profile_sands();
    callback toggle_profile_gestures();
    callback toggle_profile_shortcuts();

    // Any edit to a saveable field marks the form dirty, which is the only
    // thing that enables the save button (see the bottom save bar below).
    changed default_layout => {
        if !loading {
            dirty = true;
        }
    }
    changed default_profile_index => {
        if !loading {
            dirty = true;
        }
    }
    changed enable_log => {
        if !loading {
            dirty = true;
        }
    }
    changed activate_only_when_ime_on => {
        if !loading {
            dirty = true;
        }
    }
    changed ime_off_layout => {
        if !loading {
            dirty = true;
        }
    }
    changed combo_window_ms => {
        if !loading {
            dirty = true;
        }
    }
    changed hold_mode => {
        if !loading {
            dirty = true;
        }
    }
    changed direct_input_key_index => {
        if !loading {
            dirty = true;
        }
    }
    changed sands_mode_index => {
        if !loading {
            dirty = true;
        }
    }
    changed enable_sands_ime_on => {
        if !loading {
            dirty = true;
        }
    }
    changed enable_sands_ime_off => {
        if !loading {
            dirty = true;
        }
    }
    changed dispatch_rate_ms => {
        if !loading {
            dirty = true;
        }
    }
    changed disable_ctrl => {
        if !loading {
            dirty = true;
        }
    }
    changed disable_alt => {
        if !loading {
            dirty = true;
        }
    }
    changed disable_win => {
        if !loading {
            dirty = true;
        }
    }
    changed disable_shift => {
        if !loading {
            dirty = true;
        }
    }
    changed enable_ctrl_space_ime_toggle => {
        if !loading {
            dirty = true;
        }
    }

    HorizontalBox {
        padding: 0px;
        spacing: 0px;

        // Left pane: category list (flush, no gaps between items).
        VerticalBox {
            width: 160px;
            padding: 0px;
            spacing: 0px;
            CategoryItem {
                label: "全般";
                selected: category_index == 0;
                clicked => {
                    category_index = 0;
                }
            }

            CategoryItem {
                label: "キー無効化";
                selected: category_index == 1;
                clicked => {
                    category_index = 1;
                }
            }

            CategoryItem {
                label: "ログ";
                selected: category_index == 2;
                clicked => {
                    category_index = 2;
                }
            }

            CategoryItem {
                label: "IME";
                selected: category_index == 3;
                clicked => {
                    category_index = 3;
                }
            }

            CategoryItem {
                label: "プロセス";
                selected: category_index == 4;
                clicked => {
                    category_index = 4;
                }
            }

            Rectangle { }
        }

        // Divider line between the category list and the settings pane.
        Rectangle {
            width: 1px;
            background: #c0c0c0;
        }

        // Right pane: settings for the selected category, with a
        // save bar pinned to the bottom regardless of scroll position.
        VerticalBox {
            padding: 0px;
            spacing: 0px;

            ScrollView {
                VerticalBox {
                    if category_index == 0: VerticalBox {
                        spacing: 4px;
                        HorizontalBox {
                            Text {
                                text: "IMEオン";
                                vertical-alignment: center;
                                width: 180px;
                            }

                            LineEdit {
                                text <=> default_layout;
                                horizontal-stretch: 1;
                            }

                            Button {
                                text: "📁";
                                width: 40px;
                                height: 32px;
                                horizontal-stretch: 0;
                                clicked => {
                                    browse_default_layout();
                                }
                            }
                        }

                        HorizontalBox {
                            Text {
                                text: "IMEオフ";
                                vertical-alignment: center;
                                width: 180px;
                            }

                            Rectangle {
                                horizontal-stretch: 1;
                                height: 32px;
                                LineEdit {
                                    text <=> ime_off_layout;
                                    width: parent.width;
                                    height: parent.height;
                                    enabled: activate_only_when_ime_on;
                                }

                                if ime_off_layout == "": Text {
                                    text: "パススルー";
                                    color: gray;
                                    x: 12px;
                                    height: parent.height;
                                    vertical-alignment: center;
                                }
                            }

                            Button {
                                text: "📁";
                                width: 40px;
                                height: 32px;
                                horizontal-stretch: 0;
                                enabled: activate_only_when_ime_on;
                                clicked => {
                                    browse_ime_off_layout();
                                }
                            }
                        }

                        HorizontalBox {
                            Text {
                                text: "同時打鍵判定のしきい値 (ms)";
                                vertical-alignment: center;
                                width: 180px;
                            }

                            SpinBox {
                                width: 100px;
                                height: 32px;
                                minimum: 1;
                                maximum: 500;
                                value <=> combo_window_ms;
                            }
                        }

                        HorizontalBox {
                            CheckBox {
                                text: "IMEがオンの時だけ有効にする（オフ時は全パススルー、または上のレイアウトを使用）";
                                checked <=> activate_only_when_ime_on;
                            }
                        }

                        HorizontalBox {
                            CheckBox {
                                text: "長押し時に出力をリピートする（ホールド扱い、オフ＝単打扱い）";
                                checked <=> hold_mode;
                            }
                        }

                        HorizontalBox {
                            Text {
                                text: "直接入力キー（押している間IMEオフレイアウトを使用）";
                                vertical-alignment: center;
                                width: 180px;
                            }

                            ComboBox {
                                height: 32px;
                                vertical-stretch: 0;
                                model: ["なし", "Shift", "無変換", "変換", "CapsLock"];
                                current-index <=> direct_input_key_index;
                            }
                        }

                        HorizontalBox {
                            Text {
                                text: "SandS";
                                vertical-alignment: center;
                                width: 180px;
                            }

                            ComboBox {
                                height: 32px;
                                vertical-stretch: 0;
                                model: ["オフ", "オン（物理レイアウト）", "オン（IMEオフ）"];
                                current-index <=> sands_mode_index;
                            }
                        }

                        HorizontalBox {
                            CheckBox {
                                text: "SandS を IME オン時に有効にする";
                                checked <=> enable_sands_ime_on;
                            }
                        }

                        HorizontalBox {
                            CheckBox {
                                text: "SandS を IME オフ時に有効にする";
                                checked <=> enable_sands_ime_off;
                            }
                        }

                        HorizontalBox {
                            Text {
                                text: "処理のディスパッチレート (ms)";
                                vertical-alignment: center;
                                width: 180px;
                            }

                            SpinBox {
                                width: 100px;
                                height: 32px;
                                minimum: 1;
                                maximum: 100;
                                value <=> dispatch_rate_ms;
                            }
                        }
                    }

                    if category_index == 1: VerticalBox {
                        spacing: 4px;
                        VerticalBox {
                            CheckBox {
                                text: "Ctrl";
                                checked <=> disable_ctrl;
                            }

                            CheckBox {
                                text: "Alt";
                                checked <=> disable_alt;
                            }

                            CheckBox {
                                text: "Win";
                                checked <=> disable_win;
                            }

                            CheckBox {
                                text: "Shift";
                                checked <=> disable_shift;
                            }
                        }
                    }

                    if category_index == 2: VerticalBox {
                        spacing: 4px;
                        HorizontalBox {
                            CheckBox {
                                text: "ログを有効にする (実行ファイルと同じフォルダの ./log に出力)";
                                checked <=> enable_log;
                            }

                            Button {
                                text: "ログを開く";
                                height: 32px;
                                horizontal-stretch: 0;
                                clicked => {
                                    open_log_file();
                                }
                            }
                        }
                    }

                    if category_index == 3: VerticalBox {
                        spacing: 4px;
                        HorizontalBox {
                            CheckBox {
                                text: "Ctrl + Space で IME のオン/オフを切り替える";
                                checked <=> enable_ctrl_space_ime_toggle;
                            }
                        }
                    }

                    if category_index == 4: VerticalBox {
                        vertical-stretch: 0;
                        spacing: 4px;
                        HorizontalBox {
                            vertical-stretch: 0;
                            alignment: start;
                            Button {
                                text: daemon_suspended ? "再生" : "停止";
                                width: 80px;
                                height: 32px;
                                horizontal-stretch: 0;
                                enabled: !daemon_op_in_flight;
                                clicked => {
                                    toggle_running();
                                }
                            }

                            Button {
                                text: "再起動";
                                width: 80px;
                                height: 32px;
                                horizontal-stretch: 0;
                                enabled: !daemon_op_in_flight;
                                clicked => {
                                    restart();
                                }
                            }

                            Button {
                                text: "終了";
                                width: 80px;
                                height: 32px;
                                horizontal-stretch: 0;
                                enabled: !daemon_op_in_flight;
                                clicked => {
                                    quit();
                                }
                            }
                        }
                    }
                }
            }

            // Divider line above the always-visible save bar.
            Rectangle {
                height: 1px;
                background: #c0c0c0;
            }

            HorizontalBox {
                VerticalBox {
                    padding: 0px;
                    spacing: 2px;
                    alignment: start;
                    HorizontalBox {
                        padding: 0px;
                        spacing: 0px;
                        Text {
                            text: "状態";
                            width: 70px;
                            wrap: char-wrap;
                        }

                        Text {
                            text: running_status_text;
                            wrap: char-wrap;
                            color: running_status_text == "稼働中" ? #2ecc71 : (running_status_text == "停止中" ? #e74c3c : white);
                        }
                    }

                    HorizontalBox {
                        padding: 0px;
                        spacing: 0px;
                        Text {
                            text: "レイアウト";
                            width: 70px;
                            wrap: char-wrap;
                        }

                        Text {
                            text: current_layout_text;
                            wrap: char-wrap;
                            horizontal-stretch: 1;
                        }
                    }
                }

                Text {
                    text: status_text;
                    vertical-alignment: center;
                    horizontal-stretch: 1;
                }

                Button {
                    text: "保存";
                    width: 80px;
                    height: 32px;
                    enabled: dirty;
                    clicked => {
                        save();
                    }
                }
            }
        }
    }
}
