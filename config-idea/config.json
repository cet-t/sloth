{
  "meta": {
    "name": "my-layout",
    "keyboard": "us",
    "author": "cet-t",
    "version": "0.1"
  },
  "layers": {
    "base": {
      "grid": [
        ["`", "1", "2", "3", "4", "5", "6", "7", "8", "9", "0", "-", "+"],
        ["q", "w", "e", "r", "t", "y", "u", "i", "o", "p", "[", "]", "\\"],
        ["a", "s", "d", "f", "g", "h", "j", "k", "l", ";", "'"],
        ["z", "x", "c", "v", "b", "n", "m", ",", ".", "/"]
      ]
    },
    "shift": {
      "inherit": "base",
      "override": {
        "grid": [
          ["~", "!", "@", "#", "$", "%", "^", "&", "*", "(", ")", "_", "+"],
          ["Q", "W", "E", "R", "T", "Y", "U", "I", "O", "P", "{", "}", "|"],
          ["A", "S", "D", "F", "G", "H", "J", "K", "L", ":", "\""],
          ["Z", "X", "C", "V", "B", "N", "M", "<", ">", "?"]
        ]
      }
    },
    "kana": {
      "grid": [
        ["1", "2", "3", "4", "5", "6", "7", "8", "9", "0", "-", "^", "\\"],
        ["q", "w", "e", "r", "t", "y", "u", "i", "o", "p", "@", "[", "]"],
        ["a", "s", "d", "f", "g", "h", "j", "k", "l", ";", ":"],
        ["z", "x", "c", "v", "b", "n", "m", ",", ".", "/"]
      ]
    }
  },
  "combos": {
    "a,b": "@",
    "s,d": "#",
    "x,c": "*",
    "shift,k": "K"
  },
  "sequences": {
    "d,v": "★",
    "k,k": "々",
    "q,o": "🌟"
  },
  "states": {
    "default": "base",
    "ime_off": "base",
    "ime_on": "kana"
  }
}
